# 检查 Docker 容器是否运行
check_container() {
    if ! docker ps --format "{{.Names}}" | grep -q "^trendradar$"; then
        return 1
    fi
    return 0
}

# 查看服务状态
cmd_info() {
    echo -e "${CYAN}📊 正在获取服务状态...${NC}"
    echo ""
    
    # 显示当前运行环境
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  当前运行环境${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo ""
    
    # 获取当前环境
    CURRENT_ENV=${TRENDRADAR_ENV:-"development"}
    if [ -d "$PROD_BASE/current" ] && [[ "$PWD" == *"install/trendradar"* ]]; then
        CURRENT_ENV="production"
    fi
    
    if [ "$CURRENT_ENV" = "production" ]; then
        echo -e "${CYAN}🌐 运行环境:${NC} ${GREEN}生产环境 (PRODUCTION)${NC}"
        echo -e "${CYAN}📍 工作目录:${NC} ${YELLOW}$PWD${NC}"
        echo -e "${CYAN}🔧 监控端口:${NC} ${YELLOW}8089${NC}"
    else
        echo -e "${CYAN}🌐 运行环境:${NC} ${BLUE}开发环境 (DEVELOPMENT)${NC}"
        echo -e "${CYAN}📍 工作目录:${NC} ${YELLOW}$PWD${NC}"
        echo -e "${CYAN}🔧 监控端口:${NC} ${YELLOW}8088${NC}"
    fi
    echo ""

    # 显示生产环境部署信息
    if [ -f "$MANIFEST_FILE" ]; then
        echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
        echo -e "${BLUE}  生产环境部署信息${NC}"
        echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
        echo ""

        CURRENT_VERSION=$(get_current_version 2>/dev/null || echo "未部署")
        PREVIOUS_VERSION=$(get_previous_version 2>/dev/null || echo "null")
        VERSION_COUNT=$(list_versions 2>/dev/null | wc -l)
        DEV_VERSION=$(cat "$SCRIPT_DIR/version" 2>/dev/null | tr -d '[:space:]' || echo "未知")

        echo -e "${CYAN}📦 部署目录:${NC} ${YELLOW}$PROD_BASE${NC}"

        if [ "$CURRENT_VERSION" = "未部署" ] || [ "$CURRENT_VERSION" = "null" ]; then
            echo -e "${CYAN}🚀 生产版本:${NC} ${RED}未部署${NC}"
        else
            echo -e "${CYAN}🚀 生产版本:${NC} ${GREEN}v${CURRENT_VERSION}${NC}"
        fi

        echo -e "${CYAN}🔧 开发版本:${NC} ${BLUE}v${DEV_VERSION}${NC}"

        if [ "$PREVIOUS_VERSION" = "null" ] || [ -z "$PREVIOUS_VERSION" ]; then
            echo -e "${CYAN}⏮️  上一版本:${NC} ${YELLOW}无${NC}"
        else
            echo -e "${CYAN}⏮️  上一版本:${NC} ${YELLOW}v${PREVIOUS_VERSION}${NC}"
        fi

        echo -e "${CYAN}📚 版本总数:${NC} ${YELLOW}${VERSION_COUNT}${NC}"

        # 显示生产环境容器状态
        if docker ps --format "{{.Names}}" | grep -q "trendradar-prod"; then
            echo -e "${CYAN}🐳 生产容器:${NC} ${GREEN}运行中 ✅${NC}"
            echo ""
            docker ps --format "table {{.Names}}\t{{.Status}}" | grep -E "NAMES|trendradar-prod|trendradar-mcp-prod"
        else
            echo -e "${CYAN}🐳 生产容器:${NC} ${RED}未运行 ❌${NC}"
        fi

        echo ""
        echo -e "${CYAN}💡 管理命令:${NC}"
        echo -e "   查看所有版本: ${YELLOW}trend versions${NC}"
        echo -e "   发布新版本: ${YELLOW}trend deploy${NC}"
        echo -e "   更新版本: ${YELLOW}trend update <version>${NC}"
        echo ""
        echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
        echo ""
    fi

    # 显示开发环境状态
    cd "$DOCKER_DIR" && ./status.sh
}

# 手动触发一次
cmd_trigger() {
    echo -e "${CYAN}🚀 手动触发数据抓取和推送...${NC}"
    echo ""

    if ! check_container; then
        echo -e "${RED}❌ 错误: trendradar 容器未运行${NC}"
        echo -e "${YELLOW}💡 请先启动服务: trend start${NC}"
        exit 1
    fi

    echo -e "${YELLOW}⏳ 执行中，请稍候...${NC}"
    echo ""

    docker exec -it trendradar python manage.py run

    echo ""
    echo -e "${GREEN}✅ 执行完成！${NC}"
    echo -e "${CYAN}💡 查看最新报告: trend report${NC}"
}

# 查看实时日志
cmd_logs() {
    echo -e "${CYAN}📝 查看实时日志（按 Ctrl+C 退出）${NC}"
    echo ""

    if ! check_container; then
        echo -e "${RED}❌ 错误: trendradar 容器未运行${NC}"
        exit 1
    fi

    docker logs trendradar -f --tail 50
}

# 重启服务
cmd_restart() {
    echo -e "${YELLOW}🔄 正在重启 TrendRadar 服务...${NC}"
    echo ""

    if ! check_container; then
        echo -e "${YELLOW}⚠️  容器未运行，将直接启动${NC}"
        cmd_start
        return
    fi

    docker restart trendradar trendradar-mcp

    echo ""
    echo -e "${GREEN}✅ 服务重启成功！${NC}"
    echo ""
    sleep 2
    echo -e "${CYAN}📊 当前状态:${NC}"
    docker ps --format "table {{.Names}}\t{{.Status}}" | grep -E "NAMES|trendradar"
}

# 启动服务
cmd_start() {
    echo -e "${GREEN}🚀 正在启动 TrendRadar 服务...${NC}"
    echo ""

    if check_container; then
        echo -e "${YELLOW}⚠️  服务已在运行中${NC}"
        docker ps --format "table {{.Names}}\t{{.Status}}" | grep -E "NAMES|trendradar"
        return
    fi

    cd "$DOCKER_DIR"
    docker compose -f docker-compose-build.yml up -d

    echo ""
    echo -e "${GREEN}✅ 服务启动成功！${NC}"
    echo ""
    sleep 2
    echo -e "${CYAN}💡 查看状态: trend info${NC}"
}

# 停止服务
cmd_stop() {
    echo -e "${RED}🛑 正在停止 TrendRadar 服务...${NC}"
    echo ""

    if ! check_container; then
        echo -e "${YELLOW}⚠️  服务未运行${NC}"
        return
    fi

    echo -e "${YELLOW}❓ 确认要停止服务吗？(y/N)${NC}"
    read -r confirm

    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "${CYAN}✋ 已取消${NC}"
        return
    fi

    cd "$DOCKER_DIR"
    docker compose -f docker-compose-build.yml down

    echo ""
    echo -e "${GREEN}✅ 服务已停止${NC}"
}

# 编辑配置文件
cmd_config() {
    echo -e "${CYAN}📝 打开配置文件...${NC}"
    echo ""

    config_file="$SCRIPT_DIR/config/config.yaml"

    if [ ! -f "$config_file" ]; then
        echo -e "${RED}❌ 配置文件不存在: $config_file${NC}"
        exit 1
    fi

    # 检查可用的编辑器
    if command -v nano &> /dev/null; then
        nano "$config_file"
    elif command -v vim &> /dev/null; then
        vim "$config_file"
    elif command -v vi &> /dev/null; then
        vi "$config_file"
    else
        echo -e "${RED}❌ 未找到可用的编辑器 (nano/vim/vi)${NC}"
        echo -e "${CYAN}💡 配置文件位置: $config_file${NC}"
        exit 1
    fi

    echo ""
    echo -e "${YELLOW}⚠️  配置已修改，需要重启服务才能生效${NC}"
    echo -e "${CYAN}💡 重启服务: trend restart${NC}"
}

# 打开最新报告
cmd_report() {
    echo -e "${CYAN}📄 查找最新报告...${NC}"
    echo ""

    local latest_report=""
    local file_url=""

    # 优先查找生产环境的报告
    if [ -f "$PROD_BASE/shared/output/html/latest/current.html" ]; then
        latest_report="$PROD_BASE/shared/output/html/latest/current.html"
        echo -e "${GREEN}🌐 生产环境最新报告${NC}"
    # 查找开发环境的报告
    elif [ -f "$SCRIPT_DIR/output/html/latest/current.html" ]; then
        latest_report="$SCRIPT_DIR/output/html/latest/current.html"
        echo -e "${CYAN}🔧 开发环境最新报告${NC}"
    else
        echo -e "${RED}❌ 未找到报告文件${NC}"
        echo -e "${YELLOW}💡 手动触发一次: trend trigger${NC}"
        exit 1
    fi

    file_url="file://$latest_report"
    echo ""

    # 显示报告信息
    report_size=$(du -h "$latest_report" | awk '{print $1}')
    report_time=$(stat -c %y "$latest_report" 2>/dev/null | cut -d' ' -f1-2 || stat -f "%Sm" "$latest_report" 2>/dev/null)

    echo -e "${CYAN}📄 文件路径:${NC} $latest_report"
    echo -e "${CYAN}📏 文件大小:${NC} ${YELLOW}${report_size}${NC}"
    echo -e "${CYAN}🕒 更新时间:${NC} ${YELLOW}${report_time}${NC}"
    echo ""
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo -e "${YELLOW}🔖 固定访问地址（推荐收藏到浏览器）:${NC}"
    echo -e "${GREEN}${file_url}${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo ""

    # 检查是否启用了 Web 服务器
    if [ -f "$PROD_BASE/shared/.env" ] && grep -q "ENABLE_WEBSERVER=true" "$PROD_BASE/shared/.env" 2>/dev/null; then
        if docker ps --format "{{.Names}}" | grep -q "trendradar-prod"; then
            echo -e "${CYAN}🌐 Web 服务器地址:${NC} ${YELLOW}http://localhost:8080/html/latest/current.html${NC}"
            echo ""
        fi
    fi

    echo -e "${CYAN}💡 使用提示:${NC}"
    echo -e "   1. 复制上面的地址到浏览器打开"
    echo -e "   2. 按 ${YELLOW}Ctrl+D${NC} 收藏此页面"
    echo -e "   3. 以后打开收藏即可查看最新报告（自动更新）"
    echo ""

    # 尝试用浏览器打开
    echo -e "${GREEN}🚀 正在浏览器中打开...${NC}"
    if command -v xdg-open &> /dev/null; then
        xdg-open "$latest_report" 2>/dev/null &
    elif command -v open &> /dev/null; then
        open "$latest_report" 2>/dev/null &
    fi
}

