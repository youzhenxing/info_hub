    echo -e "  trend ${CYAN}<command>${NC}"
    echo ""
    echo -e "${BOLD}可用命令:${NC}"
    echo ""
    echo -e "  ${CYAN}info${NC} / ${CYAN}--info${NC}"
    echo -e "      查看服务状态（容器、定时任务、邮件推送等）"
    echo ""
    echo -e "  ${CYAN}trigger${NC} / ${CYAN}--trigger${NC}"
    echo -e "      手动触发一次数据抓取和推送"
    echo ""
    echo -e "  ${CYAN}logs${NC} / ${CYAN}--logs${NC}"
    echo -e "      查看实时日志（Ctrl+C 退出）"
    echo ""
    echo -e "  ${CYAN}restart${NC} / ${CYAN}--restart${NC}"
    echo -e "      重启 TrendRadar 服务"
    echo ""
    echo -e "  ${CYAN}start${NC} / ${CYAN}--start${NC}"
    echo -e "      启动 TrendRadar 服务"
    echo ""
    echo -e "  ${CYAN}stop${NC} / ${CYAN}--stop${NC}"
    echo -e "      停止 TrendRadar 服务"
    echo ""
    echo -e "  ${CYAN}config${NC} / ${CYAN}--config${NC}"
    echo -e "      编辑配置文件"
    echo ""
    echo -e "  ${CYAN}report${NC} / ${CYAN}--report${NC}"
    echo -e "      打开最新的 HTML 报告"
    echo ""
    echo -e "  ${CYAN}help${NC} / ${CYAN}--help${NC}"
    echo -e "      显示此帮助信息"
    echo ""
    echo -e "${BOLD}版本管理命令:${NC}"
    echo ""
    echo -e "  ${CYAN}deploy${NC}"
    echo -e "      发布新版本到生产环境"
    echo ""
    echo -e "  ${CYAN}update${NC} ${YELLOW}<version>${NC}"
    echo -e "      更新生产环境到指定版本"
    echo ""
    echo -e "  ${CYAN}rollback${NC}"
    echo -e "      回退到上一个版本"
    echo ""
    echo -e "  ${CYAN}versions${NC}"
    echo -e "      查看所有已部署的版本"
    echo ""
    echo -e "  ${CYAN}version-info${NC} ${YELLOW}<version>${NC}"
    echo -e "      查看指定版本的详细信息"
    echo ""
    echo -e "  ${CYAN}production${NC}"
    echo -e "      显示生产环境状态"
    echo ""
    echo -e "${BOLD}模块命令:${NC}"
    echo ""
    echo -e "  ${CYAN}run${NC} ${YELLOW}<module|all>${NC} ${YELLOW}[-f]${NC}"
    echo -e "      运行指定模块（podcast/investment/community/wechat/all）"
    echo -e "      -f 强制执行（忽略 enabled 状态）"
    echo ""
    echo -e "  ${CYAN}status${NC}"
    echo -e "      查看所有模块状态（最近执行、下次执行等）"
    echo ""
    echo -e "  ${CYAN}schedule${NC}"
    echo -e "      显示调度时间表"
    echo ""
    echo -e "  ${CYAN}health${NC}"
    echo -e "      系统健康检查（AI、邮件、数据库等）"
    echo ""
    echo -e "  ${CYAN}monitor${NC} ${YELLOW}[start|stop]${NC}"
    echo -e "      启动/停止监控网页服务器（默认端口 8088）"
    echo ""
    echo -e "  ${CYAN}community${NC}"
    echo -e "      手动触发社区监控（HackerNews/Reddit/GitHub/ProductHunt）"
    echo ""
    echo -e "${BOLD}示例:${NC}"
    echo -e "  trend info          # 查看服务状态"
