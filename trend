# 运行模块
cmd_run() {
    local module="${1:-all}"
    local force=""
    
    if [ "$2" = "-f" ] || [ "$2" = "--force" ]; then
        force="--force"
    fi
    
    cd "$SCRIPT_DIR"
    python -m trendradar.cli run "$module" $force
}

# 模块状态
cmd_module_status() {
    cd "$SCRIPT_DIR"
    python -m trendradar.cli status
}

# 调度时间表
cmd_schedule() {
    cd "$SCRIPT_DIR"
    python -m trendradar.cli schedule
}

# 健康检查
cmd_health() {
    cd "$SCRIPT_DIR"
    python -m trendradar.cli health
}

# 监控网页
cmd_monitor() {
    local subcmd="${1:-start}"
    
    # 获取当前环境
    local CURRENT_ENV=${TRENDRADAR_ENV:-"development"}
    if [ -d "$PROD_BASE/current" ] && [[ "$PWD" == *"install/trendradar"* ]]; then
        CURRENT_ENV="production"
    fi
    
    if [ "$CURRENT_ENV" = "production" ]; then
        local PORT=8089
        local ENV_LABEL="生产环境"
    else
        local PORT=8088
        local ENV_LABEL="开发环境"
    fi
    
    case "$subcmd" in
        start)
            echo -e "${CYAN}🌐 启动监控服务器...${NC}"
            echo -e "${CYAN}📍 环境: ${NC}${YELLOW}${ENV_LABEL}${NC}"
            echo -e "${CYAN}🔧 端口: ${NC}${YELLOW}${PORT}${NC}"
            echo ""
            cd "$SCRIPT_DIR"
            export TRENDRADAR_ENV="$CURRENT_ENV"
            python -m trendradar.monitor.web
            ;;
        stop)
            echo -e "${YELLOW}停止监控服务器 (${ENV_LABEL})...${NC}"
            pkill -f "trendradar.monitor.web" 2>/dev/null || echo "监控服务器未运行"
            ;;
        status)
            if curl -s "http://localhost:${PORT}/api/health" > /dev/null 2>&1; then
                echo -e "${GREEN}✓ 监控服务器运行中 (${ENV_LABEL}, 端口 ${PORT})${NC}"
            else
                echo -e "${RED}✗ 监控服务器未运行${NC}"
            fi
            ;;
        *)
            echo -e "${RED}未知子命令: $subcmd${NC}"
            echo "用法: trend monitor [start|stop|status]"
            ;;
    esac
}

# 生产环境管理
cmd_production() {
    PROD_BASE="/home/zxy/Documents/install/trendradar"

    if [ ! -d "$PROD_BASE" ]; then
        echo -e "${YELLOW}⚠️  生产环境未初始化${NC}"
        echo -e "${CYAN}💡 初始化生产环境: ./deploy/init-production.sh${NC}"
        exit 1
    fi

    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  生产环境状态${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo ""

    # 显示当前版本
    if [ -L "$PROD_BASE/current" ]; then
        current_link=$(readlink "$PROD_BASE/current")
        current_version=$(basename "$current_link")
        echo -e "${CYAN}📦 当前版本: ${YELLOW}${current_version}${NC}"
    else
        echo -e "${YELLOW}⚠️  当前版本: 未部署${NC}"
    fi

    echo ""

    # 显示容器状态
    echo -e "${CYAN}🐳 容器状态:${NC}"
    if docker ps --format "{{.Names}}" | grep -q "trendradar-prod"; then
        docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" | grep -E "NAMES|trendradar-prod"
        echo ""
        echo -e "${GREEN}  ✓ 生产服务运行正常${NC}"
    else
        echo -e "${YELLOW}  ⚠️  生产服务未运行${NC}"
        echo -e "${CYAN}  💡 启动服务: trend update <version>${NC}"
    fi

    echo ""

    # 显示目录信息
    echo -e "${CYAN}📁 目录结构:${NC}"
    echo -e "   安装位置: ${YELLOW}$PROD_BASE${NC}"
    echo -e "   配置目录: ${YELLOW}$PROD_BASE/shared/config${NC}"
    echo -e "   输出目录: ${YELLOW}$PROD_BASE/shared/output${NC}"
    echo -e "   版本数量: ${YELLOW}$(ls -1 $PROD_BASE/releases 2>/dev/null | wc -l)${NC}"

    echo ""
}

# 主逻辑
main() {
    # 如果没有参数，显示帮助
    if [ $# -eq 0 ]; then
        show_help
        exit 0
    fi

    # 处理命令
    case "$1" in
        info|--info|-i)
            cmd_info
            ;;
        trigger|--trigger|-t)
            cmd_trigger
            ;;
        logs|--logs|-l)
            cmd_logs
            ;;
        restart|--restart|-r)
            cmd_restart
            ;;
        start|--start)
            cmd_start
            ;;
        stop|--stop)
            cmd_stop
            ;;
        config|--config|-c)
            cmd_config
            ;;
        report|--report)
            cmd_report
            ;;
        deploy)
            cmd_deploy
            ;;
        update)
            cmd_update "$2"
            ;;
        rollback)
            cmd_rollback
            ;;
        versions)
            cmd_versions
            ;;
        version-info)
            cmd_version_info "$2"
            ;;
        production)
            cmd_production
            ;;
        community)
            cmd_community
            ;;
        run)
            cmd_run "$2" "$3"
            ;;
        status)
            cmd_module_status
            ;;
        schedule)
            cmd_schedule
            ;;
        health)
            cmd_health
            ;;
        monitor)
            cmd_monitor "$2"
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo -e "${RED}❌ 未知命令: $1${NC}"
            echo ""
            echo -e "${CYAN}💡 查看帮助: trend help${NC}"
            exit 1
            ;;
    esac
}

# 执行主函数
main "$@"
