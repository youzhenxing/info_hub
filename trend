# 发布新版本
cmd_deploy() {
    "$SCRIPT_DIR/deploy/deploy.sh"
}

# 更新到指定版本
cmd_update() {
    local version="$1"

    if [ -z "$version" ]; then
        echo -e "${RED}❌ 错误：请指定版本号${NC}"
        echo -e "${CYAN}用法: trend update <version>${NC}"
        echo -e "${CYAN}示例: trend update 5.5.0${NC}"
        echo ""
        echo -e "${CYAN}💡 查看可用版本: trend versions${NC}"
        exit 1
    fi

    "$SCRIPT_DIR/deploy/update.sh" "$version"
}

# 回退到上一版本
cmd_rollback() {
    "$SCRIPT_DIR/deploy/rollback.sh"
}

# 查看所有版本
cmd_versions() {
    PROD_BASE="/home/zxy/Documents/install/trendradar"
    MANIFEST_FILE="$PROD_BASE/versions/manifest.yaml"

    if [ ! -f "$MANIFEST_FILE" ]; then
        echo -e "${YELLOW}⚠️  生产环境未初始化${NC}"
        echo -e "${CYAN}💡 初始化生产环境: ./deploy/init-production.sh${NC}"
        echo -e "${CYAN}💡 发布第一个版本: trend deploy${NC}"
        exit 1
    fi

    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  已部署版本列表${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo ""

    # 读取当前版本
    current_version=$(grep "^current_version:" "$MANIFEST_FILE" | awk '{print $2}' | tr -d '"' | tr -d "'")

    # 列出所有版本
    if [ -d "$PROD_BASE/releases" ]; then
        printf "%-15s %-12s %-25s %s\n" "VERSION" "STATUS" "RELEASED" "IMAGE"
        echo "─────────────────────────────────────────────────────────────────────────"

        # 从 manifest.yaml 读取版本信息
        while IFS= read -r line; do
            if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*version:[[:space:]]*\"(.*)\" ]]; then
                version="${BASH_REMATCH[1]}"

                # 读取该版本的其他信息
                status=""
                released=""
                image=""

                # 读取接下来的几行
                while IFS= read -r next_line; do
                    if [[ "$next_line" =~ ^[[:space:]]*status:[[:space:]]*\"(.*)\" ]]; then
                        status="${BASH_REMATCH[1]}"
                    elif [[ "$next_line" =~ ^[[:space:]]*released_at:[[:space:]]*\"(.*)\" ]]; then
                        released="${BASH_REMATCH[1]}"
                        # 格式化时间
                        released=$(echo "$released" | cut -d'T' -f1)
                    elif [[ "$next_line" =~ ^[[:space:]]*image:[[:space:]]*\"(.*)\" ]]; then
                        image="${BASH_REMATCH[1]}"
                        break
                    elif [[ "$next_line" =~ ^[[:space:]]*-[[:space:]]*version ]]; then
                        break
                    fi
                done

                # 标记当前版本
                if [ "$version" = "$current_version" ]; then
                    status="${GREEN}active${NC}   ⭐"
                else
                    status="${YELLOW}${status}${NC}"
                fi

                printf "%-15s %-22s %-25s %s\n" "v$version" "$status" "$released" "$image"
            fi
        done < "$MANIFEST_FILE"
    else
        echo -e "${YELLOW}未找到已部署的版本${NC}"
    fi

    echo ""
    echo -e "${CYAN}💡 有用的命令:${NC}"
    echo -e "  查看版本详情: ${YELLOW}trend version-info <version>${NC}"
    echo -e "  更新到新版本: ${YELLOW}trend update <version>${NC}"
    echo -e "  回退到上一版: ${YELLOW}trend rollback${NC}"
    echo ""
}

# 查看版本详细信息
cmd_version_info() {
    local version="$1"

    if [ -z "$version" ]; then
        echo -e "${RED}❌ 错误：请指定版本号${NC}"
        echo -e "${CYAN}用法: trend version-info <version>${NC}"
        echo -e "${CYAN}示例: trend version-info 5.4.0${NC}"
        exit 1
    fi

    # 去掉版本号前的 v
    version="${version#v}"

    HISTORY_FILE="/home/zxy/Documents/install/trendradar/versions/history/v${version}.yaml"

    if [ ! -f "$HISTORY_FILE" ]; then
        echo -e "${RED}❌ 错误：版本 v${version} 的记录不存在${NC}"
        echo -e "${CYAN}💡 查看可用版本: trend versions${NC}"
        exit 1
    fi

    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  版本详细信息: v${version}${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo ""

    cat "$HISTORY_FILE"
}

